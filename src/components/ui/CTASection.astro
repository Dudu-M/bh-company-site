---
import { Image } from 'astro:assets';
import Button from './Button.astro';
import defaultBackgroundImage from '../../assets/mining.webp';

interface Props {
  title: string;
  description: string;
  primaryButtonText?: string;
  primaryButtonHref?: string;
  secondaryButtonText?: string;
  secondaryButtonHref?: string;
  backgroundImage?: string | any;
}

const { 
  title, 
  description,
  primaryButtonText = 'Get Started',
  primaryButtonHref = 'mailto:nyabunzen@gmail.com',
  secondaryButtonText,
  secondaryButtonHref,
  backgroundImage = defaultBackgroundImage
} = Astro.props;
---

<section class="relative section-spacing overflow-hidden bg-primary-900">
  <!-- Background Image -->
  <div class="absolute inset-0 z-0 bg-primary-900">
    {typeof backgroundImage === 'string' ? (
      <img
        src={backgroundImage}
        alt="Background"
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
    ) : (
      <Image
        src={backgroundImage}
        alt="Background"
        class="w-full h-full object-cover"
        widths={[640, 1024, 1600, 1920]}
        sizes="100vw"
        loading="eager"
        priority
      />
    )}
  </div>
  
  <!-- Gradient Overlay - Top to bottom -->
  <div class="absolute inset-0 z-10 bg-gradient-to-b from-primary-900/50 via-primary-900/80 to-primary-900/90"></div>
  
  <!-- Content -->
  <div class="container-custom text-center relative z-20">
    <h2 class="text-white mb-6 !text-white">{title}</h2>
    <p class="text-white/90 text-xl max-w-3xl mx-auto mb-8">
      {description}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <Button href={primaryButtonHref} variant="primary" size="lg">
        {primaryButtonText}
      </Button>
      {secondaryButtonText && (
        <Button href={secondaryButtonHref} variant="outline" size="lg" class="!text-white !border-white hover:!bg-white hover:!text-primary-900">
          {secondaryButtonText}
        </Button>
      )}
    </div>
  </div>
</section>